{
  "name": "jhste-skills",
  "version": "0.1.0",
  "description": "Installable engineering guardrails and workflow skills for AI coding agents.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jhste102lab/jhste-skills.git"
  },
  "bin": {
